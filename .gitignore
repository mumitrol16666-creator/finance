# ============================================================
# Environment / secrets
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# Python cache & bytecode
# ============================================================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ============================================================
# Virtual environments
# ============================================================
.venv/
venv/
env/
ENV/

# ============================================================
# Linters / type-checkers / test caches
# ============================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.cover

# ============================================================
# IDE / editor
# ============================================================
.idea/
.vscode/
*.iml
*.swp
*.swo
*~
.DS_Store

# ============================================================
# Databases
# ============================================================
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.db-journal
data/*.db
data/*.db-*
scripts/*.db
scripts/*.db-*

# ============================================================
# Logs
# ============================================================
logs/
*.log

# ============================================================
# Archives
# ============================================================
*.7z
*.zip
*.rar
*.tar.gz
*.tar

# ============================================================
# OS artifacts
# ============================================================
Thumbs.db
Desktop.ini
.DS_Store

# ============================================================
